# Local backend configuration for the production-faithful stack.
#
#   cp .env.example .env
#
# Loaded automatically by every pixi task that touches settings — the backend
# (start-backend), Alembic (db-upgrade), and the importer all go through
# data_rover.api.settings.get_settings(), whose pydantic SettingsConfigDict has
# env_file=".env". pixi runs tasks from the repo root, so this file is found.
# (Real OS env vars still override these; .env overrides the code defaults.)
#
# Values match docker-compose.yml. .env is gitignored — keep secrets here, not
# in .env.example.

# --- Tenancy / content database (docker-compose `postgres`) ---
DATA_ROVER_DATABASE_URL=postgresql+psycopg://data_rover:data_rover@localhost:5432/data_rover

# --- Snapshot blob store (docker-compose `fake-gcs`) ---
# "gcs" uses the real google-cloud-storage client; STORAGE_EMULATOR_HOST points
# it at fake-gcs-server. In real production: drop STORAGE_EMULATOR_HOST (uses
# real GCS + default credentials) and set the real bucket.
DATA_ROVER_SNAPSHOT_STORE=gcs
DATA_ROVER_GCS_BUCKET=data-rover-snapshots
DATA_ROVER_STORAGE_EMULATOR_HOST=http://localhost:4443

# --- Dev convenience ---
# Auto-seed a model into project `default` on startup.
# MUST be false in real production (Postgres schema is Alembic-owned).
DATA_ROVER_DEV_SEED=true

# Seed source artifacts (paths relative to the repo root). Leave unset to use
# the bundled examples/smart-city.* — set these to seed a different model.
DATA_ROVER_SEED_METAMODEL=examples/smart-city.metamodel.yaml
DATA_ROVER_SEED_MODEL=examples/smart-city.model.json
DATA_ROVER_SEED_VIEW=examples/smart-city.view.json

# Extra dev users pre-provisioned as members of `default` on seed. NOTE: these
# users get NO password, so they cannot use the cookie login — they are only
# usable with the legacy header identity provider (see below), or to pre-wire
# membership for users you later give a password to in the admin console. Copy
# the template first:  cp dev-users.example.json dev-users.json
DATA_ROVER_DEV_USERS_FILE=dev-users.json

# --- Auth / first admin user ---
# Identity provider: "cookie" (real email+password login — the default) or
# "header" (trusts X-User-Id / ?user= — dev/gateway/API automation only; the
# browser frontend no longer sends identity headers, so header mode is for
# curl/tests, not the SPA).
# DATA_ROVER_IDENTITY_PROVIDER=cookie

# JWT signing secret for cookie sessions. The code default below is INSECURE and
# the backend REFUSES to boot with it when identity_provider=cookie and
# dev_seed=false (production). Set a long random value in production.
# DATA_ROVER_JWT_SECRET=dev-insecure-secret-change-me

# First admin (production seeding). On every startup the backend ensures this
# user exists and is an admin (create-or-promote) — independent of dev_seed, so
# a fresh prod deploy has someone to log in as (there is no self-signup; admins
# create all other users). Leave the email empty to skip. In dev (dev_seed=true)
# with no bootstrap email set, a default admin@example.com / admin12345 is
# seeded instead.
# DATA_ROVER_BOOTSTRAP_ADMIN_EMAIL=
# DATA_ROVER_BOOTSTRAP_ADMIN_PASSWORD=
