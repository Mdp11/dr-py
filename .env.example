# Local backend configuration for the production-faithful stack.
#
#   cp .env.example .env
#
# Loaded automatically by every pixi task that touches settings — the backend
# (start-backend), Alembic (db-upgrade), and the importer all go through
# data_rover.api.settings.get_settings(), whose pydantic SettingsConfigDict has
# env_file=".env". pixi runs tasks from the repo root, so this file is found.
# (Real OS env vars still override these; .env overrides the code defaults.)
#
# Values match docker-compose.yml. .env is gitignored — keep secrets here, not
# in .env.example.

# --- Tenancy / content database (docker-compose `postgres`) ---
DATA_ROVER_DATABASE_URL=postgresql+psycopg://data_rover:data_rover@localhost:5432/data_rover

# --- Snapshot blob store (docker-compose `fake-gcs`) ---
# "gcs" uses the real google-cloud-storage client; STORAGE_EMULATOR_HOST points
# it at fake-gcs-server. In real production: drop STORAGE_EMULATOR_HOST (uses
# real GCS + default credentials) and set the real bucket.
DATA_ROVER_SNAPSHOT_STORE=gcs
DATA_ROVER_GCS_BUCKET=data-rover-snapshots
DATA_ROVER_STORAGE_EMULATOR_HOST=http://localhost:4443

# --- Dev convenience ---
# Auto-seed examples/smart-city.* into project `default` on startup.
# MUST be false in real production (Postgres schema is Alembic-owned).
DATA_ROVER_DEV_SEED=true
